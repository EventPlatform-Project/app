# Copy to .env and edit if you need non-default values.

# HTTP server
PORT=9000

# How many recent notifications to keep in memory
MAX_HISTORY=100

# --- Eureka registration ---
# Set EUREKA_DISABLED=true if you want to skip registering (e.g. in tests).
EUREKA_HOST=localhost
EUREKA_PORT=8761
# The IP the gateway will use to reach us. Use your LAN IP if the gateway
# runs in a different container or on another host; otherwise leave as-is.
EUREKA_INSTANCE_HOST=localhost
EUREKA_INSTANCE_IP=127.0.0.1
