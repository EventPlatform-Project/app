# =====================================================================
# Bootstrap env for the notification-service.
#
# All application settings (mongo URI, RabbitMQ URL, queue names, etc.)
# are pulled from the Spring Cloud Config server on startup, from
#   config-repo/notification-service.properties
#
# Only the "how do I reach infra" variables belong here.
# =====================================================================

# Config-server that serves notification-service.properties.
# Leave empty to skip and use built-in defaults from src/config/env.js.
CONFIG_SERVER_URL=http://localhost:8889

# Eureka discovery server.
EUREKA_HOST=localhost
EUREKA_PORT=8761

# Placeholders resolved inside notification-service.properties.
#   MONGO_HOST     -> notification.mongo.uri
#   RABBITMQ_HOST  -> notification.rabbitmq.url
MONGO_HOST=localhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Hostname advertised to Eureka. Must be reachable BY THE OTHER SERVICES.
#   - Docker compose:  notification-service   (the container name)
#   - Host / local:    localhost
NOTIFICATION_INSTANCE_HOST=localhost
NOTIFICATION_INSTANCE_IP=127.0.0.1

# --- Optional overrides for the config client itself ---
# CONFIG_APP_NAME=notification-service
# CONFIG_PROFILE=default
# CONFIG_LABEL=main
# CONFIG_RETRIES=5
# CONFIG_RETRY_DELAY_MS=3000
# CONFIG_TIMEOUT_MS=5000
